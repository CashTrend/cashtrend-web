{
  /**
   * tsconfig.check.json -- TypeScript config for the quality-gate check script.
   *
   * Extends the main tsconfig.json but excludes the .next/ build directory.
   * The .next/types/validator.ts file auto-generated by Next.js can reference
   * non-existent route handlers (e.g. for rewrite-based proxy paths that have
   * no corresponding route.ts file), which causes spurious type errors when
   * running a bare `tsc --noEmit`.
   *
   * next build handles these generated types correctly internally, so we only
   * exclude them from the standalone typecheck step in the check script.
   * The main tsconfig.json is unchanged and continues to work for the IDE and
   * for `next build`.
   */
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", ".next"]
}
